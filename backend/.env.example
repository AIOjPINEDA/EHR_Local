# ============================================
# ConsultaMed Backend - Environment Variables
# ============================================
# Copia este archivo a .env y configura los valores

# Effective URL consumed by backend runtime.
# Local profile:
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:54329/consultamed
# Supabase profile:
# DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:54329/consultamed

# JWT Authentication
CONSULTAMED_JWT_SECRET_KEY=your-super-secret-key-change-in-production
CONSULTAMED_JWT_ALGORITHM=HS256
CONSULTAMED_ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS
CONSULTAMED_FRONTEND_URL=http://localhost:3000

# Environment
CONSULTAMED_ENVIRONMENT=development
CONSULTAMED_DEBUG=true
